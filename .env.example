REACT_APP_GEMINI_API_KEY=

# OpenWeather (free tier): https://openweathermap.org/api
REACT_APP_OPENWEATHER_API_KEY=

# Supabase project URL + anon key
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
