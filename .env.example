# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — DO NOT commit real keys.

# Supabase project URL + anon key (Settings -> API). Required for auth + tasks.
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# OpenWeather (free tier): https://openweathermap.org/api
REACT_APP_OPENWEATHER_API_KEY=

# NOTE: The Todo app's free-tier Gemini key is NO LONGER a frontend var.
# It now lives only in the Supabase Edge Function as a secret:
#   supabase secrets set GEMINI_API_KEY=<your rotated key>
# Users' own keys (bring-your-own) are entered in the app UI and stored
# only in their browser's localStorage — never here.
